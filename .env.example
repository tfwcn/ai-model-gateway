# AI Model Gateway - 环境变量配置文件
# 复制此文件为 .env 并填入真实的API密钥

# ModelScope API 密钥
MODELSCOPE_API_KEY=your-modelscope-api-key-here

# OpenRouter API 密钥  
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenAI API 密钥（如果启用OpenAI平台）
OPENAI_API_KEY=your-openai-api-key-here

# Azure OpenAI API 密钥（如果启用Azure平台）
AZURE_API_KEY=your-azure-api-key-here

# 其他平台的API密钥可以按需添加
# PLATFORM_NAME_API_KEY=your-api-key-here

# Redis 配置 (用于 Responses API 会话状态管理)
REDIS_URL=redis://localhost:6379
RESPONSES_SESSION_TTL=86400

# 日志配置 (简化版)
# DEBUG=true                    # 启用 DEBUG 级别日志 (默认 INFO)
# ENABLE_CONSOLE_LOGS=false     # 禁用控制台输出 (默认 true)
# LOG_DIR=logs                  # 日志目录 (默认 logs/)